# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Resend (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxx

# Uygulama URL'i
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EPC Karar Destek

# Cross-subdomain SSO için cookie domain'i (lider nokta önemli)
# Tüm fozanseyfi.com subdomain'leri auth'u paylaşsın diye kullanılır.
# Local'de boş bırak — sadece production'da .fozanseyfi.com'a set edilmeli.
NEXT_PUBLIC_COOKIE_DOMAIN=.fozanseyfi.com

# Sistem admini (migration ile seed için)
ADMIN_EMAIL=ozan.seyfi@kontrolmatik.com
